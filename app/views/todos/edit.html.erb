<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header bg-primary text-white">
        <h3>Edit Todo</h3>
      </div>
      <div class="card-body">
        <%= render 'form', todo: @todo %>
      </div>
      <div class="card-footer">
        <%= link_to 'Back to Todos', todos_path, class: 'btn btn-secondary' %>
      </div>
    </div>
  </div>
</div>