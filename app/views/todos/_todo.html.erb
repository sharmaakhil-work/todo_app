<% 
  status_classes = {
    "not_started" => "",
    "in_progress" => "list-group-item-warning",
    "completed" => "list-group-item-success"
  }
  
  status_icons = {
    "not_started" => "fa-circle",
    "in_progress" => "fa-spinner fa-spin",
    "completed" => "fa-check-circle"
  }
  
  status_colors = {
    "not_started" => "text-secondary",
    "in_progress" => "text-warning",
    "completed" => "text-success"
  }
%>

<div class="list-group-item d-flex justify-content-between align-items-center <%= status_classes[todo.status] %>" id="todo-<%= todo.id %>">
  <div class="d-flex align-items-center flex-grow-1">
    <div class="dropdown">
      <button class="btn dropdown-toggle p-0 me-2" type="button" id="statusDropdown<%= todo.id %>" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="fa <%= status_icons[todo.status] %> fa-lg <%= status_colors[todo.status] %>"></i>
      </button>
      <ul class="dropdown-menu" aria-labelledby="statusDropdown<%= todo.id %>">
        <li>
          <%= button_to update_status_todo_path(todo, status: "not_started"), method: :patch, class: "dropdown-item #{'active' if todo.not_started?}" do %>
            <i class="fa fa-circle me-2 text-secondary"></i> Not Started
          <% end %>
        </li>
        <li>
          <%= button_to update_status_todo_path(todo, status: "in_progress"), method: :patch, class: "dropdown-item #{'active' if todo.in_progress?}" do %>
            <i class="fa fa-spinner me-2 text-warning"></i> In Progress
          <% end %>
        </li>
        <li>
          <%= button_to update_status_todo_path(todo, status: "completed"), method: :patch, class: "dropdown-item #{'active' if todo.completed?}" do %>
            <i class="fa fa-check-circle me-2 text-success"></i> Completed
          <% end %>
        </li>
      </ul>
    </div>
    
    <div class="ms-2 flex-grow-1">
      <h5 class="mb-1 <%= 'text-decoration-line-through' if todo.completed? %>"><%= todo.title %></h5>
      <% if todo.description.present? %>
        <p class="mb-1 text-muted small <%= 'text-decoration-line-through' if todo.completed? %>"><%= truncate(todo.description, length: 100) %></p>
      <% end %>
      <div class="d-flex align-items-center">
        <% if todo.due_date.present? %>
          <small class="me-2">
            <i class="fa fa-calendar"></i> 
            <%= todo.due_date.strftime("%b %d, %Y") %>
          </small>
        <% end %>
        
        <% if todo.priority.present? %>
          <% badge_class = case todo.priority
             when "high" then "badge bg-danger"
             when "medium" then "badge bg-warning"
             when "low" then "badge bg-info"
             end %>
          <span class="<%= badge_class %>"><%= todo.priority.capitalize %></span>
        <% end %>
        
        <% status_badge_class = case todo.status
           when "not_started" then "badge bg-secondary ms-2"
           when "in_progress" then "badge bg-warning text-dark ms-2"
           when "completed" then "badge bg-success ms-2"
           end %>
        <span class="<%= status_badge_class %>">
          <%= todo.status.humanize %>
        </span>
      </div>
    </div>
  </div>
  
  <div class="d-flex">
    <%= link_to edit_todo_path(todo), class: "btn btn-sm btn-outline-primary me-1" do %>
      <i class="fa fa-edit"></i>
    <% end %>
    
    <%= button_to todo_path(todo), method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Are you sure?" } } do %>
      <i class="fa fa-trash"></i>
    <% end %>
  </div>
</div>