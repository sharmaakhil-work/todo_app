<div class="row">
  <div class="col-md-4 mb-4">
    <div class="card">
      <div class="card-header bg-primary text-white">
        <h3>Add New Todo</h3>
      </div>
      <div class="card-body">
        <%= render 'form', todo: @todo %>
      </div>
    </div>
  </div>
  
  <div class="col-md-8">
    <div class="card">
      <div class="card-header bg-primary text-white">
        <h3>My Todos</h3>
      </div>
      <div class="card-body">
        <div class="list-group" id="todos-list">
          <% if @todos.empty? %>
            <p class="text-center">No todos yet. Create your first one!</p>
          <% else %>
            <%= render @todos %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Function to handle completion toggle
    const toggleButtons = document.querySelectorAll('.toggle-completed');
    toggleButtons.forEach(button => {
      button.addEventListener('click', function(e) {
        const todoId = this.dataset.todoId;
        const formId = `toggle-form-${todoId}`;
        document.getElementById(formId).submit();
      });
    });
  });
</script>